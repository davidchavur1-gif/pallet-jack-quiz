<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#1a4fd6;
  --bg2:#1848c8;
  --bg3:#1540b8;
  --surface:rgba(255,255,255,0.08);
  --surface2:rgba(255,255,255,0.12);
  --blue:#ffffff;
  --blue2:#a8c8ff;
  --blue3:#cce0ff;
  --text:#ffffff;
  --muted:rgba(255,255,255,0.65);
  --border:rgba(255,255,255,0.15);
  --green:#00e676;
  --dark:#0a2a7a;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden}

/* animated background blobs */
body::before{
  content:'';position:fixed;top:-20%;right:-10%;width:60vw;height:80vh;
  background:radial-gradient(circle,rgba(255,255,255,0.06) 0%,transparent 65%);
  pointer-events:none;z-index:0;
}
body::after{
  content:'';position:fixed;bottom:-20%;left:-10%;width:50vw;height:60vh;
  background:radial-gradient(circle,rgba(0,0,0,0.12) 0%,transparent 65%);
  pointer-events:none;z-index:0;
}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:15px 40px;display:flex;align-items:center;justify-content:space-between;background:rgba(20,64,184,0.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-name{font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:#fff}
.nav-links{display:flex;gap:4px}
.nav-links a{font-size:12px;font-weight:600;color:rgba(255,255,255,0.6);text-decoration:none;transition:all 0.2s;padding:6px 12px;border-radius:8px;cursor:pointer}
.nav-links a:hover{color:#fff;background:rgba(255,255,255,0.1)}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;padding:110px 60px 60px;max-width:1200px;margin:auto;gap:0;position:relative;z-index:1}

/* PHOTO LEFT */
.hero-left{flex-shrink:0;position:relative;margin-right:64px}
.photo-wrap{width:300px;height:380px;border-radius:24px;overflow:hidden;border:3px solid rgba(255,255,255,0.3);position:relative;box-shadow:0 32px 80px rgba(0,0,0,0.35)}
.photo-wrap img{width:100%;height:100%;object-fit:cover;object-position:center 5%}
.digi-float{position:absolute;bottom:-16px;left:50%;transform:translateX(-50%);background:rgba(255,255,255,0.15);backdrop-filter:blur(12px);border:1.5px solid rgba(255,255,255,0.3);border-radius:14px;padding:9px 18px;display:flex;align-items:center;gap:10px;box-shadow:0 8px 24px rgba(0,0,0,0.2);cursor:pointer;transition:all 0.2s;white-space:nowrap}
.digi-float:hover{background:rgba(255,255,255,0.22);transform:translateX(-50%) scale(1.04)}
.digi-float img{height:18px;filter:brightness(0) invert(1)}

/* NAME RIGHT */
.hero-right{flex:1;padding-left:20px}
.hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.25);border-radius:20px;padding:7px 18px;font-size:11px;font-weight:700;color:#fff;margin-bottom:24px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;transition:all 0.2s}
.hero-tag:hover{background:rgba(255,255,255,0.2)}
.hero-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:blink 1.6s infinite;flex-shrink:0;box-shadow:0 0 8px rgba(0,230,118,0.7)}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
h1.hero-name{font-family:'Syne',sans-serif;font-size:clamp(44px,5.5vw,76px);font-weight:800;line-height:0.95;color:#fff;margin-bottom:14px}
h1.hero-name .last{color:rgba(255,255,255,0.4)}
.hero-title{font-size:17px;color:rgba(255,255,255,0.7);margin-bottom:12px;font-weight:500}
.hero-contact{font-size:14px;color:rgba(255,255,255,0.65);margin-bottom:30px;line-height:2.1}
.hero-contact span{cursor:pointer;transition:all 0.2s;border-radius:6px;padding:2px 8px}
.hero-contact span:hover{color:#fff;background:rgba(255,255,255,0.12)}
.hero-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:36px}
.hbadge{font-size:12px;font-weight:600;padding:7px 15px;border-radius:10px;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.8);background:rgba(255,255,255,0.08);cursor:pointer;transition:all 0.2s;user-select:none}
.hbadge:hover{background:rgba(255,255,255,0.18);color:#fff;transform:translateY(-2px)}
.hero-btn{display:inline-flex;align-items:center;gap:10px;background:#fff;color:var(--dark);padding:14px 30px;border-radius:11px;font-weight:700;font-size:14px;text-decoration:none;transition:all 0.2s;box-shadow:0 4px 24px rgba(0,0,0,0.2);cursor:pointer;border:none}
.hero-btn:hover{background:var(--blue3);transform:translateY(-3px);box-shadow:0 8px 32px rgba(0,0,0,0.3)}

/* SECTIONS — white cards on blue bg */
section{padding:80px 40px;max-width:1100px;margin:auto;position:relative;z-index:1}
.section-label{font-size:11px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:10px}
.section-title{font-family:'Syne',sans-serif;font-size:clamp(26px,4vw,38px);font-weight:800;color:#fff;margin-bottom:36px}
.divider{width:100%;height:1px;background:rgba(255,255,255,0.1);margin-bottom:80px;position:relative;z-index:1}

/* CARDS */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.about-card{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.18);border-radius:16px;padding:22px;transition:all 0.25s;cursor:default;backdrop-filter:blur(4px)}
.about-card:hover{background:rgba(255,255,255,0.16);transform:translateY(-3px)}
.about-card-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.55);margin-bottom:12px}
.about-card p{font-size:14px;color:rgba(255,255,255,0.8);line-height:1.7}
.skills-wrap{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.skill{font-size:12px;font-weight:600;padding:6px 12px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.75);background:rgba(255,255,255,0.08);cursor:pointer;transition:all 0.15s;user-select:none}
.skill:hover{background:rgba(255,255,255,0.2);color:#fff;transform:translateY(-2px)}

/* EXP */
.exp-list{display:flex;flex-direction:column}
.exp-item{display:grid;grid-template-columns:20px 1fr;gap:0 24px;padding:28px 0;border-bottom:1px solid rgba(255,255,255,0.1)}
.exp-item:last-child{border-bottom:none}
.exp-line{display:flex;flex-direction:column;align-items:center;padding-top:5px}
.exp-dot{width:12px;height:12px;border-radius:50%;background:#fff;flex-shrink:0;box-shadow:0 0 0 3px rgba(255,255,255,0.2),0 0 12px rgba(255,255,255,0.3)}
.exp-connector{flex:1;width:1px;background:rgba(255,255,255,0.15);margin-top:6px}
.exp-header{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:4px;flex-wrap:wrap}
.exp-role{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;color:#fff}
.exp-date{font-size:11px;font-weight:700;color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);padding:4px 10px;border-radius:20px;white-space:nowrap}
.exp-company{font-size:13px;font-weight:600;color:rgba(255,255,255,0.6);margin-bottom:12px}
.exp-bullets{display:flex;flex-direction:column;gap:6px}
.exp-bullet{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:rgba(255,255,255,0.7);line-height:1.5}
.exp-bullet::before{content:'›';color:rgba(255,255,255,0.5);font-weight:700;flex-shrink:0}

/* PROJECTS */
.projects-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.proj-card{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:16px;overflow:hidden;transition:all 0.25s;cursor:pointer;position:relative}
.proj-card:hover{background:rgba(255,255,255,0.14);transform:translateY(-5px);box-shadow:0 24px 48px rgba(0,0,0,0.3)}
.proj-card::after{content:'🔍 Ver ampliado';position:absolute;top:0;left:0;right:0;height:190px;background:rgba(10,42,122,0.85);color:#fff;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s}
.proj-card:hover::after{opacity:1}
.proj-img-wrap{width:100%;height:190px;overflow:hidden}
.proj-img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;transition:transform 0.4s}
.proj-card:hover .proj-img{transform:scale(1.05)}
.proj-info{padding:14px 16px}
.proj-tag{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.5);margin-bottom:5px}
.proj-title{font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.proj-desc{font-size:12px;color:rgba(255,255,255,0.55);line-height:1.5}

/* LIGHTBOX */
#lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.96);z-index:999;align-items:center;justify-content:center;padding:20px}
#lightbox.show{display:flex}
#lightbox img{max-width:92vw;max-height:88vh;border-radius:10px}
#lb-close{position:fixed;top:18px;right:22px;background:rgba(255,255,255,0.1);border:none;color:#fff;font-size:18px;cursor:pointer;width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center}
#lb-close:hover{background:rgba(255,255,255,0.2)}

/* VIDEO */
.video-section{padding:80px 40px;max-width:1100px;margin:auto;position:relative;z-index:1}
.video-note{font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:16px;padding:10px 16px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:10px;display:inline-block}
.video-outer{border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,0.2);box-shadow:0 20px 60px rgba(0,0,0,0.35);position:relative;padding-bottom:56.25%;height:0}
.video-outer iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none}

/* EDU */
.edu-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.edu-card{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:16px;padding:24px;transition:all 0.25s;cursor:default}
.edu-card:hover{background:rgba(255,255,255,0.14);transform:translateY(-3px)}
.edu-degree{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:#fff;margin-bottom:6px}
.edu-school{font-size:12px;font-weight:600;color:rgba(255,255,255,0.6);margin-bottom:6px}
.edu-date{font-size:11px;color:rgba(255,255,255,0.5);margin-bottom:10px;display:inline-block;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);padding:3px 10px;border-radius:10px}
.edu-desc{font-size:13px;color:rgba(255,255,255,0.55);line-height:1.6}

footer{background:rgba(0,0,0,0.2);border-top:1px solid rgba(255,255,255,0.1);padding:40px;text-align:center;position:relative;z-index:1}
footer p{font-size:13px;color:rgba(255,255,255,0.5);line-height:2}
footer a{color:rgba(255,255,255,0.8);text-decoration:none}
footer a:hover{color:#fff}

.fade-in{opacity:0;transform:translateY(20px);transition:opacity 0.55s ease,transform 0.55s ease}
.fade-in.visible{opacity:1;transform:translateY(0)}

#toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);background:#fff;color:var(--dark);font-size:13px;font-weight:700;padding:10px 22px;border-radius:24px;opacity:0;transition:all 0.3s;pointer-events:none;z-index:500;white-space:nowrap;box-shadow:0 8px 24px rgba(0,0,0,0.2)}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

@media(max-width:768px){
  .hero{flex-direction:column;padding:88px 20px 40px;gap:32px}
  .hero-left{margin-right:0}
  .photo-wrap{width:240px;height:300px}
  nav{padding:14px 20px}
  .nav-links a{font-size:11px;padding:5px 8px}
  section,.video-section{padding:60px 20px}
  .about-grid,.projects-grid,.edu-grid{grid-template-columns:1fr}
}
</style>
</head>
